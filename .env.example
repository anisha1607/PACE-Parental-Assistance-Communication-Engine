


# PACE – Environment Configuration

# HOW TO USE:
#   1. Uncomment ONE block under "Generation LLM" and fill in your key
#   2. Uncomment ONE block under "Judge LLM" and fill in your key
#      (can be the same provider as generation, or a different one)
#   3. Optionally adjust BART and guard settings




# GENERATION LLM
# Uncomment ONE block below.


#  Groq 
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY="your_groq_key_here"

#  Anthropic 
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=your_anthropic_key_here

#  OpenAI 
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_key_here

# Ollama (local, no API key needed) 
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:latest
# OLLAMA_BASE_URL=http://localhost:11434

#  Any OpenAI-compatible endpoint 
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=your-model-name
# OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPAT_API_KEY=optional



# JUDGE LLM
# Independent of generation — can be same or different provider.
# If not set, falls back to generation LLM automatically.
# Uncomment ONE block below, or leave all commented to use generation LLM.


#  Groq 
# JUDGE_PROVIDER=groq
# JUDGE_MODEL=llama-3.1-8b-instant
# (no extra key needed if already using Groq for generation)

#  Anthropic 
JUDGE_PROVIDER=anthropic
JUDGE_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY="your_anthropic_key_here"

#  OpenAI 
# JUDGE_PROVIDER=openai
# JUDGE_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_key_here

#  Ollama (local, no API key needed) 
# JUDGE_PROVIDER=ollama
# JUDGE_MODEL=llama3.1:latest
# OLLAMA_BASE_URL=http://localhost:11434

#  Any OpenAI-compatible endpoint 
# JUDGE_PROVIDER=openai_compatible
# JUDGE_MODEL=your-model-name
# OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPAT_API_KEY=optional



# BART GUARD SETTINGS


# Faster, lighter model (recommended for CPU)
BART_MODEL=valhalla/distilbart-mnli-12-1

# Full model (more accurate, slower on CPU)
# BART_MODEL=facebook/bart-large-mnli

# Confidence threshold — lower = stricter, higher = more permissive
GUARD_THRESHOLD=0.50



# DISTRESS BACKSTOP SETTINGS (optional — defaults shown)


# Set to "false" to disable distress detection entirely
# DISTRESS_ENABLED=true

# Suicide classifier threshold (0-1, higher = less sensitive)
# DISTRESS_SUICIDE_THRESHOLD=0.65

# Severity classifier thresholds (0-5 scale)
# DISTRESS_SEVERITY_HIGH=4
# DISTRESS_SEVERITY_MEDIUM=3